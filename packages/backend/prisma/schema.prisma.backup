generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NOTE: SQLite does not support enums. Use String fields + application-level validation.
// MerchantStatus: "ACTIVE" | "INACTIVE" | "OFFBOARDED"
// KycStatus: "PENDING" | "APPROVED" | "REJECTED" | "SUPPLEMENT_REQUIRED"
// PaymentMethodStatus: "PENDING" | "ACTIVE" | "INACTIVE"
// NotificationType: "REGISTRATION_STATUS" | "PAYMENT_METHOD_ACTIVATION_STATUS" | "RISK_NOTIFICATION"

model Merchant {
  id                    String   @id @default(uuid())
  shopName              String
  region                String   @default("CN")
  email                 String
  wfAccountId           String?
  referenceMerchantId   String?  @unique  // platform-side reference ID for Antom
  kycStatus             String   @default("PENDING")
  riskLevel             String?
  riskReasonCodes       String?  // JSON string
  registrationRequestId String?
  offboardingRequestId  String?  // separate from registration per Antom spec
  settlementCurrency    String   @default("HKD")
  status                String   @default("ACTIVE")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  kycInfo              KycInfo?
  paymentMethods       PaymentMethod[]
  notifications        Notification[]
  entityAssociations   EntityAssociation[]
}

model KycInfo {
  id              String   @id @default(uuid())
  merchantId      String   @unique
  merchant        Merchant @relation(fields: [merchantId], references: [id])

  // Company info
  legalName       String?
  companyType     String?  // ENTERPRISE, PARTNERSHIP, SOLE_PROPRIETORSHIP, etc.
  certificateType String?  // ENTERPRISE_REGISTRATION, LICENSE_INFO, etc.
  certificateNo   String?
  branchName      String?
  companyUnit     String?  // BRANCH, HEADQUARTERS

  // Registered address
  addressRegion   String?
  addressState    String?
  addressCity     String?
  address1        String?
  address2        String?
  zipCode         String?

  // Business info
  mcc             String?  // 4-digit merchant category code
  doingBusinessAs String?
  websiteUrl      String?
  englishName     String?
  serviceDescription String?
  appName         String?  // store/application name
  merchantBrandName String?

  // Contact
  contactType     String?  // EMAIL, PHONE_NO, CS_PHONE_NO
  contactInfo     String?

  // Entity association (legal representative - kept for backward compat)
  legalRepName    String?
  legalRepIdType  String?  // ID_CARD, PASSPORT, DRIVING_LICENSE
  legalRepIdNo    String?
  legalRepDob     String?  // ISO 8601 date

  // WF OAuth pre-filled data
  wfKycData       String?  // JSON string
  rejectedFields  String?  // JSON string

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Directors / UBOs per Antom entityAssociations spec
model EntityAssociation {
  id                String   @id @default(uuid())
  merchantId        String
  merchant          Merchant @relation(fields: [merchantId], references: [id])

  associationType   String   // DIRECTOR, UBO
  shareholdingRatio String?  // Antom: all non-array values must be String
  fullName          String?
  firstName         String?
  lastName          String?
  dateOfBirth       String?  // ISO 8601
  idType            String?  // ID_CARD, PASSPORT, DRIVING_LICENSE
  idNo              String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([merchantId])
}

model PaymentMethod {
  id                String   @id @default(uuid())
  merchantId        String
  merchant          Merchant @relation(fields: [merchantId], references: [id])
  paymentMethodType String
  status            String   @default("PENDING")
  activatedAt       DateTime?
  deactivatedAt     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Notification {
  id               String   @id @default(uuid())
  merchantId       String
  merchant         Merchant @relation(fields: [merchantId], references: [id])
  notifyId         String   @unique
  notificationType String
  payload          String   // JSON string
  processedAt      DateTime @default(now())
}
